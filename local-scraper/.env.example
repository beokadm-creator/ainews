# Local Scraper Server Configuration

# Server Port
PORT=3001

# Optional: Request timeout (ms)
TIMEOUT=30000

# Optional: Browser headless mode
HEADLESS=true

# Optional: Debug logging
DEBUG=false

# ─── Firebase / Firestore ────────────────────────────────────────────────────
# Firebase project ID (required to push articles to Firestore)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to Firebase service account JSON key file (download from Firebase Console)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=C:\Users\whhol\ainews\firebase-service-account.json

# Company ID in Firestore (articles will be tagged with this companyId)
COMPANY_ID=your-company-id

# Auto-collection interval in milliseconds (default: 3600000 = 1 hour)
# Set to 0 to disable auto-collection
COLLECT_INTERVAL_MS=3600000

# ─── SMTP 이메일 알림 ─────────────────────────────────────────────────────────
# 스크래퍼 오류 발생 시 이메일 알림 발송 (설정 안 하면 알림 비활성화)
# Gmail 사용 예: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=your@gmail.com SMTP_PASS=앱비밀번호
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
# 알림 수신 이메일 (미설정 시 SMTP_USER로 발송)
SMTP_ALERT_TO=admin@yourcompany.com
